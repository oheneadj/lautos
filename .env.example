APP_NAME="Livingston Autos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# AdminUserSeeder uses these to create the super_admin account. If left
# unset, it falls back to admin@livingstonautos.com / password — a publicly
# guessable login. Set real values here before ever running db:seed against
# a production database.
ADMIN_EMAIL=admin@livingstonautos.com
ADMIN_PASSWORD=password

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------
# DATABASE — switch to mysql for production
# ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=livingston_autos
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------
# SESSION / CACHE / QUEUE
# ---------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=file

# ---------------------------------------------------------------
# REDIS (used by Horizon and cache)
# ---------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# MAIL — uses Brevo SMTP in production.
# Locally, run `mailpit` (smtp on :1025, web UI at http://127.0.0.1:8025)
# and every email the app sends will land there instead of a real inbox.
# ---------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@livingstonautos.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------
# AWS S3 — public bucket for car images, private for KYC docs
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_KYC_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------
# GOOGLE OAUTH — "Continue with Google" on login/register
# ---------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ---------------------------------------------------------------
# SMS — GiantSMS (Ghana)
# ---------------------------------------------------------------
GIANTSMS_API_KEY=
GIANTSMS_SENDER_ID=LivingstonA

# ---------------------------------------------------------------
# FILAMENT ADMIN
# ---------------------------------------------------------------
FILAMENT_FILESYSTEM_DISK=s3

# ---------------------------------------------------------------
# BACKUPS — spatie/laravel-backup
# ---------------------------------------------------------------
# I default this to 'local' so backups work out of the box, but on shared
# hosting it should point somewhere off-server (e.g. 's3') so a backup
# actually survives if the hosting account itself is lost.
BACKUP_DISK=local
BACKUP_NOTIFICATION_EMAIL=

# ---------------------------------------------------------------
# ERROR TRACKING — Sentry
# ---------------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"

VITE_APP_NAME="${APP_NAME}"
