APP_NAME="Livingston Autos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------
# DATABASE — switch to mysql for production
# ---------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=livingston_autos
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------
# SESSION / CACHE / QUEUE
# ---------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ---------------------------------------------------------------
# REDIS (used by Horizon and cache)
# ---------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# MAIL — use Mailgun or Resend in production
# ---------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@livingstonautos.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------
# AWS S3 — public bucket for car images, private for KYC docs
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_KYC_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------
# SMS — Arkesel (Ghana)
# ---------------------------------------------------------------
SMS_PROVIDER=arkesel
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=LivingstonA

# ---------------------------------------------------------------
# FILAMENT ADMIN
# ---------------------------------------------------------------
FILAMENT_FILESYSTEM_DISK=s3

VITE_APP_NAME="${APP_NAME}"
